# Configuración de Firebase (Consola → Configuración del proyecto → Tus apps)
# Nunca commitear el archivo .env real.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Desarrollo local contra el Firestore Emulator (npx firebase-tools emulators:start)
# Con "true" no se necesitan credenciales reales.
VITE_USE_FIREBASE_EMULATOR=false

# Protección (preparado, no activo todavía)
# Cloudflare Turnstile — se integrará como proveedor de App Check.
VITE_TURNSTILE_SITE_KEY=
# Clave del proveedor de Firebase App Check (reCAPTCHA v3 o Turnstile custom).
VITE_FIREBASE_APP_CHECK_KEY=
