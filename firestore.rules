rules_version = '2';

// ⚠️ MVP: el panel /admin aún no tiene autenticación, por lo que isAdmin()
// devuelve true y las escrituras administrativas quedan abiertas.
// TODO(roadmap): al agregar login de Google, reemplazar isAdmin() por una
// verificación real (por ejemplo `request.auth.token.admin == true`) y estas
// reglas quedan listas sin más cambios.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return true; // TODO: request.auth != null && request.auth.token.admin == true
    }

    // Voto público: solo puede cambiar el campo `votes`, solo puede crecer y
    // con un delta acotado (debe coincidir con MAX_VOTES_PER_FLUSH en
    // src/constants/appConfig.ts).
    function isVoteIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes'])
        && request.resource.data.votes is int
        && request.resource.data.votes > resource.data.votes
        && request.resource.data.votes - resource.data.votes <= 100;
    }

    match /settings/app {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /battles/{battleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /options/{optionId} {
        allow read: if true;
        allow create, delete: if isAdmin();
        allow update: if isVoteIncrement() || isAdmin();
      }
    }
  }
}
